{
  "name": "fixed-income-tracker",
  "private": true,
  "version": "1.0.0",
  "description": "Mobile-first fixed income portfolio tracker for fixed deposits, SCSS, bonds, maturity rollovers, and interest reinvestment.",
  "type": "module",
  "keywords": [
    "react",
    "vite",
    "express",
    "mongodb",
    "fixed-deposits",
    "scss",
    "bonds",
    "portfolio-tracker"
  ],
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test",
    "audit": "npm audit",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
